# Some plugins (e.g. vite-plugin-pwa) declare peer ranges that lag the installed
# versions. pnpm warns rather than failing (strict-peer-dependencies defaults to
# false); these are set explicitly so installs never hard-fail and missing peers
# are pulled in automatically.
auto-install-peers=true
strict-peer-dependencies=false

# vite-plugin-pwa injects a `virtual:pwa-register` module into the app bundle
# that imports `workbox-window`. Under pnpm's isolated node_modules that
# transitive dep isn't resolvable from the project root, so Rollup fails with
# "failed to resolve import 'workbox-window'". Hoist the workbox runtime
# packages to the top level so the virtual module can resolve them.
public-hoist-pattern[]=workbox-window
public-hoist-pattern[]=workbox-*
