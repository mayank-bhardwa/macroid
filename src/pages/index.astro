---
import Base from "../layouts/Base.astro";
---
<Base>

    <div class="bg-orb orb-a"></div>
    <div class="bg-orb orb-b"></div>

    <header class="app-header">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M6 4v6a4 4 0 0 0 8 0V4M10 4v16M18 4c-1.6 1.1-2.4 3.2-2.4 5.3s.8 3.3 2.4 4.2V20"/></svg>
        </span>
        <div class="brand-text">
          <span class="brand-name">Recomp</span>
          <span class="plan-badge"><strong id="activePlanLabel">June 2026</strong></span>
        </div>
      </div>
      <button id="openAdminBtn" class="icon-btn" type="button" aria-label="Admin / defaults" title="Admin / defaults">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg>
      </button>
    </header>

    <div id="installBanner" class="install-banner" hidden>
      <span class="install-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M12 4v10m0 0 4-4m-4 4-4-4M5 18h14"/></svg>
      </span>
      <span class="install-copy">Install Recomp for one-tap access &amp; offline use.</span>
      <button id="installBtn" class="btn install-btn" type="button">Install</button>
      <button id="installDismiss" class="install-dismiss" type="button" aria-label="Dismiss">&times;</button>
    </div>

    <nav class="tab-nav" id="tabNav">
      <button class="tab active" data-tab="macros">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13h4v7H4zM10 4h4v16h-4zM16 9h4v11h-4z"/></svg>
        <span>Macros</span>
      </button>
      <button class="tab" data-tab="daily">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3v8a3 3 0 0 0 6 0V3M9 3v18M17 3c-1.5 1-2 3-2 5s.5 3 2 4v9"/></svg>
        <span>Daily</span>
      </button>
      <button class="tab" data-tab="trends">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 19V5M4 19h16M8 16l4-5 3 3 5-7"/></svg>
        <span>Trends</span>
      </button>
      <button class="tab" data-tab="mealprep">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 8h14l-1 12H6zM5 8l1-4h12l1 4M9 12v4M15 12v4"/></svg>
        <span>Prep</span>
      </button>
      <button class="tab" data-tab="grocery">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M6 6l1 13h10l1-13M9 10v6M15 10v6"/></svg>
        <span>Grocery</span>
      </button>
    </nav>

    <main>
      <section id="tab-macros" class="panel active">
        <div class="panel-top">
          <div class="panel-title">
            <span class="panel-eyebrow">Today</span>
            <h2>Daily Macros</h2>
          </div>
          <div class="date-stepper">
            <button id="macroPrev" class="step-btn" type="button" aria-label="Previous day">&lsaquo;</button>
            <label class="date-field">
              <input id="macroDate" type="date" />
            </label>
            <button id="macroNext" class="step-btn" type="button" aria-label="Next day">&rsaquo;</button>
            <button id="macroToday" class="today-btn" type="button" hidden>Today</button>
          </div>
        </div>

        <p id="macroLockNote" class="lock-note" hidden></p>

        <article class="card hero-card">
          <div class="rings">
            <div class="ring-hero">
              <svg viewBox="0 0 120 120" class="ring" aria-hidden="true">
                <circle class="ring-track" cx="60" cy="60" r="52"></circle>
                <circle class="ring-fill cal-stroke" id="calorieRing" cx="60" cy="60" r="52"></circle>
              </svg>
              <div class="ring-center">
                <span class="ring-value" id="calorieValue">0</span>
                <span class="ring-sub" id="calorieMetric">/ 2400 kcal</span>
              </div>
            </div>
            <div class="macro-rings">
              <div class="macro-ring">
                <div class="ring-wrap">
                  <svg viewBox="0 0 72 72" class="ring" aria-hidden="true">
                    <circle class="ring-track" cx="36" cy="36" r="30"></circle>
                    <circle class="ring-fill p-stroke" id="proteinRing" cx="36" cy="36" r="30"></circle>
                  </svg>
                  <span class="ring-value small" id="proteinValue">0</span>
                </div>
                <p class="macro-cap"><span class="dot p"></span>Protein</p>
                <p class="macro-sub" id="proteinMetric">/ 160g</p>
              </div>
              <div class="macro-ring">
                <div class="ring-wrap">
                  <svg viewBox="0 0 72 72" class="ring" aria-hidden="true">
                    <circle class="ring-track" cx="36" cy="36" r="30"></circle>
                    <circle class="ring-fill c-stroke" id="carbRing" cx="36" cy="36" r="30"></circle>
                  </svg>
                  <span class="ring-value small" id="carbValue">0</span>
                </div>
                <p class="macro-cap"><span class="dot c"></span>Carbs</p>
                <p class="macro-sub" id="carbMetric">/ 260g</p>
              </div>
              <div class="macro-ring">
                <div class="ring-wrap">
                  <svg viewBox="0 0 72 72" class="ring" aria-hidden="true">
                    <circle class="ring-track" cx="36" cy="36" r="30"></circle>
                    <circle class="ring-fill f-stroke" id="fatRing" cx="36" cy="36" r="30"></circle>
                  </svg>
                  <span class="ring-value small" id="fatValue">0</span>
                </div>
                <p class="macro-cap"><span class="dot f"></span>Fats</p>
                <p class="macro-sub" id="fatMetric">/ 65g</p>
              </div>
            </div>
          </div>
        </article>

        <article class="card water-card">
          <div class="water-head">
            <h3>Water</h3>
            <span class="water-count" id="waterCount">0 / 8 glasses</span>
          </div>
          <div class="water-track" id="waterTrack" aria-hidden="true"></div>
          <div class="water-actions">
            <button id="waterMinus" class="water-btn" type="button" aria-label="Remove a glass">&minus;</button>
            <span class="water-ml" id="waterMl">0 ml / 2000 ml</span>
            <button id="waterPlus" class="water-btn" type="button" aria-label="Add a glass">+</button>
          </div>
        </article>

        <article class="card">
            <h3>Add Meal Entry</h3>
            <div class="quick-add-head" id="quickAddHead" hidden>
              <span class="quick-add-label">Quick add</span>
            </div>
            <div id="recentMeals" class="quick-chips" hidden></div>
            <form id="mealForm" class="meal-form">
              <input id="mealName" type="text" placeholder="Meal name (e.g., Oats + whey)" required />
              <input id="mealProtein" type="number" min="0" step="0.1" placeholder="Protein" required />
              <input id="mealCarbs" type="number" min="0" step="0.1" placeholder="Carbs" required />
              <input id="mealFats" type="number" min="0" step="0.1" placeholder="Fats" required />
              <input id="mealCalories" type="number" min="0" step="1" placeholder="Calories (optional)" />
              <button class="btn" type="submit">Add</button>
            </form>
            <div id="mealEntries" class="list"></div>
        </article>

        <article class="card trend-card">
          <div class="trend-head">
            <h3>Trends</h3>
            <div class="seg trend-seg" id="trendRangeSeg">
              <button type="button" class="seg-btn active" data-range="7">7 days</button>
              <button type="button" class="seg-btn" data-range="30">30 days</button>
            </div>
          </div>
          <div class="trend-stats" id="trendStats"></div>
          <div class="trend-chart" id="trendChart"></div>
          <p class="trend-legend"><span class="dot p"></span>Protein vs goal &middot; bar height = % of target &middot; line = goal</p>
        </article>
      </section>

      <section id="tab-daily" class="panel">
        <div class="panel-top">
          <h2>Daily Meal Prep</h2>
          <div class="date-stepper">
            <button id="morningPrev" class="step-btn" type="button" aria-label="Previous day">&lsaquo;</button>
            <label class="date-field">
              <input id="morningDate" type="date" />
            </label>
            <button id="morningNext" class="step-btn" type="button" aria-label="Next day">&rsaquo;</button>
            <button id="morningToday" class="today-btn" type="button" hidden>Today</button>
          </div>
        </div>

        <p id="dailyLockNote" class="lock-note" hidden></p>

        <div class="day-type-row">
          <p id="dayTypeBadge" class="day-type-badge">Training day</p>
          <div class="day-actions">
            <button id="resetDayBtn" class="day-reset-btn" type="button" hidden>Reset to default</button>
            <button id="swapDayBtn" class="day-swap-btn" type="button">Swap with next day</button>
          </div>
        </div>

        <article class="card">
          <h3>Morning</h3>
          <p class="hint">Tap <strong>Pack</strong> when you box an item in the morning. Tick the checkbox when you actually <strong>eat</strong> it — only that logs to your macros.</p>
          <div id="mealsMorning" class="meal-list"></div>
        </article>

        <article class="card">
          <h3>Evening</h3>
          <p class="hint">Dinner (and optional before-bed protein).</p>
          <div id="mealsEvening" class="meal-list"></div>
        </article>

        <article class="card">
          <h3>Add custom item</h3>
          <form id="morningTaskForm" class="inline-form">
            <select id="mealGroupSelect">
              <option value="Morning">Morning</option>
              <option value="Evening">Evening</option>
            </select>
            <input id="morningTaskInput" type="text" placeholder="Custom meal / note" required />
            <button class="btn" type="submit">Add</button>
          </form>
        </article>
      </section>

      <section id="tab-trends" class="panel">
        <div class="panel-top">
          <div class="panel-title">
            <span class="panel-eyebrow">History</span>
            <h2>Trends</h2>
          </div>
          <div class="month-nav">
            <button id="historyPrev" class="month-nav-btn" type="button" aria-label="Previous period">&lsaquo;</button>
            <span id="historyLabel" class="month-label">&mdash;</span>
            <button id="historyNext" class="month-nav-btn" type="button" aria-label="Next period">&rsaquo;</button>
          </div>
        </div>

        <div class="seg history-seg" id="historyPeriodSeg" role="tablist" aria-label="History period">
          <button type="button" class="seg-btn active" data-period="daily">Daily</button>
          <button type="button" class="seg-btn" data-period="weekly">Weekly</button>
          <button type="button" class="seg-btn" data-period="monthly">Monthly</button>
          <button type="button" class="seg-btn" data-period="yearly">Yearly</button>
        </div>

        <div id="historySummary" class="month-summary"></div>

        <article class="card trend-card">
          <div class="trend-head">
            <h3 id="historyChartTitle">Protein vs goal</h3>
            <div class="seg trend-seg" id="historyMetricSeg" aria-label="Metric">
              <button type="button" class="seg-btn active" data-metric="protein">Protein</button>
              <button type="button" class="seg-btn" data-metric="calories">Calories</button>
            </div>
          </div>
          <div class="trend-chart" id="historyChart"></div>
          <p class="trend-legend"><span class="dot p" id="historyLegendDot"></span><span id="historyLegend">Bar height = % of goal &middot; dashed line = goal</span></p>
        </article>

        <article class="card">
          <h3>Breakdown</h3>
          <div id="historyBreakdown" class="history-list"></div>
          <p class="hint" id="historyHint" hidden>Tap a day to open it in the Macros &amp; Daily tabs.</p>
        </article>
      </section>

      <section id="tab-mealprep" class="panel">
        <div class="panel-top">
          <h2>Weekly Meal Prep</h2>
          <div class="inline-fields">
            <label>
              Week
              <select id="mealPrepWeek"></select>
            </label>
          </div>
        </div>

        <p id="mealPrepLockNote" class="lock-note" hidden></p>

        <article class="card">
          <p class="hint">Run this on Sunday: boil, portion, and pack.
          </p>
          <div id="mealPrepChecklist" class="checklist"></div>
          <form id="mealPrepTaskForm" class="inline-form">
            <input id="mealPrepTaskInput" type="text" placeholder="Add custom weekly prep task" required />
            <button class="btn" type="submit">Add Task</button>
          </form>
        </article>
      </section>

      <section id="tab-grocery" class="panel">
        <div class="panel-top">
          <h2>Grocery</h2>
        </div>

        <article class="card">
          <div class="card-head">
            <h3>Weekly Grocery</h3>
            <label class="inline-label">
              Week
              <select id="weeklySelect"></select>
            </label>
          </div>
          <p class="hint">Dairy plan: buy paneer + curd + milk every 2 days.</p>
          <p id="weeklyLockNote" class="lock-note" hidden></p>
          <div id="weeklyGroceryList" class="checklist"></div>
          <form id="weeklyItemForm" class="inline-form">
            <input id="weeklyItemName" type="text" placeholder="Item" required />
            <input id="weeklyItemQty" type="text" placeholder="Quantity" required />
            <button class="btn" type="submit">Add Item</button>
          </form>
        </article>

        <article class="card">
          <div class="card-head">
            <h3>Monthly Stock</h3>
            <label class="inline-label">
              Month
              <input id="monthlySelect" type="month" />
            </label>
          </div>
          <div id="monthlyTableWrap" class="table-wrap"></div>
          <div id="restockSummary" class="restock-summary"></div>
          <p class="hint">Tip: Update current stock every Sunday night for reorder decisions.</p>
        </article>
      </section>

      <section id="tab-admin" class="panel">
        <div class="panel-top">
          <div class="panel-title">
            <span class="panel-eyebrow">Master</span>
            <h2>Settings</h2>
          </div>
          <button id="closeAdminBtn" class="btn ghost" type="button">Done</button>
        </div>

        <div class="admin-subnav" id="adminSubNav" role="tablist">
          <button class="admin-subtab active" type="button" role="tab" data-subtab="defaults">Defaults</button>
          <button class="admin-subtab" type="button" role="tab" data-subtab="sync">Sync &amp; Data</button>
        </div>

        <div class="admin-subpanel active" id="adminSub-defaults" role="tabpanel">
          <p class="hint">
            Edit the <strong>default values</strong> the app seeds into new days, weeks and months.
            Your already-logged data stays untouched. Use <strong>Reset</strong> to restore a section
            to the original app defaults.
          </p>

          <article class="card">
            <div class="card-head">
              <h3>Macro Targets</h3>
              <button id="resetTargetsBtn" class="link-btn" type="button">Reset to app default</button>
            </div>
            <p class="hint">Used by the macro rings and goal celebration.</p>
            <div class="admin-grid four">
              <label>Protein (g)<input id="adminTargetProtein" type="number" min="0" step="1" /></label>
              <label>Carbs (g)<input id="adminTargetCarbs" type="number" min="0" step="1" /></label>
              <label>Fats (g)<input id="adminTargetFats" type="number" min="0" step="1" /></label>
              <label>Calories<input id="adminTargetCalories" type="number" min="0" step="1" /></label>
            </div>
            <div class="admin-actions">
              <button id="saveTargetsBtn" class="btn" type="button">Save Targets</button>
            </div>
            <p id="adminTargetsStatus" class="sync-status"></p>
          </article>

          <article class="card">
            <div class="card-head">
              <h3>Daily Meal Prep Template</h3>
              <button id="resetDailyBtn" class="link-btn" type="button">Reset to app default</button>
            </div>
            <p class="hint">Meals seeded into each day. Switch between Training and Rest day templates.</p>
            <div class="seg" id="adminDayTypeSeg">
              <button class="seg-btn active" type="button" data-daytype="training">Training day</button>
              <button class="seg-btn" type="button" data-daytype="rest">Rest day</button>
            </div>
            <div id="adminDailyRows" class="admin-rows"></div>
            <div class="admin-actions">
              <button id="adminDailyAddBtn" class="btn ghost" type="button">+ Add meal</button>
              <button id="saveDailyBtn" class="btn" type="button">Save Template</button>
            </div>
            <p id="adminDailyStatus" class="sync-status"></p>
          </article>

          <article class="card">
            <div class="card-head">
              <h3>Weekly Prep Tasks</h3>
              <button id="resetWeeklyPrepBtn" class="link-btn" type="button">Reset to app default</button>
            </div>
            <p class="hint">Sunday prep checklist seeded into each week.</p>
            <div id="adminWeeklyPrepRows" class="admin-rows"></div>
            <div class="admin-actions">
              <button id="adminWeeklyPrepAddBtn" class="btn ghost" type="button">+ Add task</button>
              <button id="saveWeeklyPrepBtn" class="btn" type="button">Save Tasks</button>
            </div>
            <p id="adminWeeklyPrepStatus" class="sync-status"></p>
          </article>

          <article class="card">
            <div class="card-head">
              <h3>Weekly Grocery Defaults</h3>
              <button id="resetWeeklyGroceryBtn" class="link-btn" type="button">Reset to app default</button>
            </div>
            <label class="inline-label">
              Week
              <select id="adminWeekSelect"></select>
            </label>
            <div id="adminWeeklyGroceryRows" class="admin-rows"></div>
            <div class="admin-actions">
              <button id="adminWeeklyGroceryAddBtn" class="btn ghost" type="button">+ Add item</button>
              <button id="saveWeeklyGroceryBtn" class="btn" type="button">Save Week Items</button>
            </div>
            <p id="adminWeeklyGroceryStatus" class="sync-status"></p>
          </article>

          <article class="card">
            <div class="card-head">
              <h3>Monthly Stock Defaults</h3>
              <button id="resetMonthlyBtn" class="link-btn" type="button">Reset to app default</button>
            </div>
            <p class="hint">Reorder-buffer rows seeded into each month's Monthly Stock table.</p>
            <div id="adminMonthlyRows" class="admin-rows"></div>
            <div class="admin-actions">
              <button id="adminMonthlyAddBtn" class="btn ghost" type="button">+ Add row</button>
              <button id="saveMonthlyBtn" class="btn" type="button">Save Stock Rows</button>
            </div>
            <p id="adminMonthlyStatus" class="sync-status"></p>
          </article>

          <article class="card danger-card">
            <h3>Reset Everything</h3>
            <p class="hint">
              Restore <strong>all default values</strong> (macros, meals, grocery, stock) to the
              original app defaults. Your logged macros, checkmarks and stock entries are not deleted,
              but the current day/week/month templates are re-seeded from the app defaults.
            </p>
            <div class="admin-actions">
              <button id="resetAllDefaultsBtn" class="btn danger" type="button">Reset all to app defaults</button>
            </div>
            <p id="adminResetAllStatus" class="sync-status"></p>
          </article>
        </div>

        <div class="admin-subpanel" id="adminSub-sync" role="tabpanel" hidden>
          <p class="hint">
            Install the app, back up your data, and sync across devices. These settings live only on
            this device unless you push them to the cloud.
          </p>

          <article class="card">
            <h3>Install App</h3>
            <p class="hint">
              Add Recomp to your home screen for a full-screen, offline, app-like experience.
            </p>
            <div class="sync-actions">
              <button id="installBtn2" class="btn">Install / Add to Home Screen</button>
            </div>
            <p id="installHint" class="sync-status"></p>
          </article>

          <article class="card">
            <h3>Monthly Plan (JSON)</h3>
            <p class="hint">
              This app is plan-driven. Load a new month's diet + grocery plan by
              importing its JSON file. Current and future months each have their own file.
            </p>
            <div class="sync-actions">
              <label class="btn file-btn">
                Load Plan JSON
                <input id="planInput" type="file" accept="application/json" />
              </label>
              <button id="downloadPlanTemplateBtn" class="btn ghost">Download Plan Template</button>
            </div>
            <p id="planStatus" class="sync-status">Using built-in June 2026 plan.</p>
          </article>

          <article class="card">
            <h3>Cloud Sync (Account)</h3>
            <p class="hint">
              Sign in to sync your data across devices. Everything keeps working
              offline — changes save locally first and sync in the background.
            </p>

            <div id="cloudSignedOut" class="sync-fields">
              <label>
                Email
                <input id="authEmail" type="email" autocomplete="username" placeholder="you@example.com" />
              </label>
              <label>
                Password
                <input id="authPassword" type="password" autocomplete="current-password" placeholder="At least 8 characters" />
              </label>
              <div class="sync-actions">
                <button id="signInBtn" class="btn">Sign In</button>
                <button id="registerBtn" class="btn ghost">Create Account</button>
              </div>
              <details class="sync-help">
                <summary>Advanced: custom API URL</summary>
                <label>
                  API base URL (leave blank for same site)
                  <input id="apiBaseInput" type="text" autocomplete="off" placeholder="https://recomp.pages.dev" />
                </label>
                <p class="hint">Only needed when running the app on a different origin than the API.</p>
              </details>
            </div>

            <div id="cloudSignedIn" hidden>
              <p class="hint">Signed in as <strong id="signedInEmail"></strong></p>
              <label class="switch-row">
                <input id="autoSyncToggle" type="checkbox" />
                <span>Auto-sync on changes and on app open</span>
              </label>
              <div class="sync-actions">
                <button id="syncNowBtn" class="btn">Sync Now</button>
                <button id="signOutBtn" class="btn ghost">Sign Out</button>
              </div>
            </div>

            <p id="syncStatus" class="sync-status">Not signed in.</p>
          </article>

          <article class="card">
            <h3>Local Backup</h3>
            <p class="hint">Export or import all your tracked data as a JSON file on this device.</p>
            <div class="sync-actions">
              <button id="exportBtn2" class="btn ghost">Export Data</button>
              <label class="btn ghost file-btn">
                Import Data
                <input id="importInput2" type="file" accept="application/json" />
              </label>
            </div>
          </article>
        </div>
      </section>
    </main>

    <div id="adminModal" class="modal-overlay" hidden>
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="adminModalTitle">
        <h3 id="adminModalTitle">Saved</h3>
        <p id="adminModalBody" class="modal-body"></p>
        <div class="modal-actions">
          <button id="adminModalDismiss" class="btn ghost" type="button">Keep current data</button>
          <button id="adminModalApply" class="btn" type="button">Apply</button>
        </div>
      </div>
    </div>

    <template id="checkItemTemplate">
      <label class="check-row">
        <input type="checkbox" />
        <span class="check-text"></span>
        <span class="qty"></span>
      </label>
